media_turma = 0.0

for _ in range(quantidade_alunos):
    soma = 0.0
    for _ in range(quantidade_notas):
        soma += float(input())
    media_aluno = soma / quantidade_notas
    media_turma += media_aluno
    print(f"{media_aluno:.2f}")

media_turma /= quantidade_alunos
print(f"{media_turma:.2f}")

